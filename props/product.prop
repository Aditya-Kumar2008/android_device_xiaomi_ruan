# Product properties for Xiaomi Ruan (Poco Pad 5G / Redmi Pad Pro 5G)

# Audio
ro.audio.monitor_rotation=true
ro.audio.monitor_window_rotation=true

# Bluetooth
ro.bluetooth.a2dp_offload.supported=true
ro.bluetooth.emb_wp_mode=false
ro.bluetooth.wipower=false

# Camera
ro.camera.notify_nfc=1

# Display
ro.display.type=LCD
ro.display.refresh_rate=120

# DRM
ro.netflix.bsp_rev=Q7435-37043-1

# SoC
ro.product.board=parrot

# Tablet-specific
ro.build.characteristics=tablet
